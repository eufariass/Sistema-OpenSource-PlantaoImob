# Connection string PostgreSQL (obrigatória)
# Exemplo Supabase: postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Opcional
# PORT=3000
# DB_READ_CACHE_TTL_MS=15000
# PG_POOL_MAX=10
# PG_CONNECTION_TIMEOUT_MS=8000

# Opcional: ativa Supabase Realtime no frontend (TV/Admin)
